---
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center px-6 pt-28 pb-20"
>
  <div class="max-w-4xl w-full mx-auto">
    <!-- Availability badge -->
    <div data-anim="hero-badge" class="flex items-center gap-2 mb-8">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 rounded-full"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"
        ></span>
        Disponible para nuevos proyectos
      </span>
    </div>

    <!-- Headline -->
    <h1
      data-anim="hero-title"
      class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.08] mb-6"
    >
      <span class="text-white">Hola, soy</span>
      <br />
      <span
        class="bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent"
      >
        Miller Bermeo
      </span>
    </h1>

    <!-- Role -->
    <p
      data-anim="hero-role"
      class="text-xl sm:text-2xl text-zinc-400 font-medium mb-5"
    >
      Desarrollador Fullstack · Backend · IA &amp; Automatización
    </p>

    <!-- Value proposition -->
    <p
      data-anim="hero-desc"
      class="text-base sm:text-lg text-zinc-500 max-w-2xl leading-relaxed mb-10"
    >
      Construyo sistemas que resuelven problemas reales de negocio: desde plataformas
      SaaS y POS hasta chatbots inteligentes y automatizaciones con IA.
      <span class="text-zinc-300 font-medium"
        >3 años de experiencia, 1.5 en producción profesional.</span
      >
    </p>

    <!-- CTAs -->
    <div
      data-anim="hero-cta"
      class="flex flex-wrap items-center gap-4 mb-12"
    >
      <a
        href="#projects"
        class="px-6 py-3 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/20"
      >
        Ver proyectos →
      </a>
      <a
        href="cvmillerrivera.pdf"
        target="_blank"
        class="px-6 py-3 text-sm font-semibold text-zinc-300 bg-white/[.05] hover:bg-white/[.08] border border-white/[.08] rounded-lg transition-all duration-200"
      >
        Descargar CV
      </a>
      <a
        href="#contact"
        class="px-6 py-3 text-sm font-medium text-zinc-500 hover:text-zinc-300 transition-colors duration-200"
      >
        Trabajemos juntos ↓
      </a>
    </div>

    <!-- Social links -->
    <div
      data-anim="hero-social"
      class="flex flex-wrap items-center gap-6"
    >
      <a
        href="https://github.com/millerbermeo"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-zinc-600 hover:text-white transition-colors duration-200"
      >
        <ion-icon name="logo-github" class="text-lg"></ion-icon>
        <span>GitHub</span>
      </a>
      <span class="w-px h-4 bg-white/10"></span>
      <a
        href="https://www.linkedin.com/in/miller-rivera/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-zinc-600 hover:text-white transition-colors duration-200"
      >
        <ion-icon name="logo-linkedin" class="text-lg"></ion-icon>
        <span>LinkedIn</span>
      </a>
      <span class="w-px h-4 bg-white/10"></span>
      <a
        href="mailto:devmiller25@gmail.com"
        class="flex items-center gap-2 text-sm text-zinc-600 hover:text-white transition-colors duration-200"
      >
        <ion-icon name="mail-outline" class="text-lg"></ion-icon>
        <span>devmiller25@gmail.com</span>
      </a>
    </div>
  </div>
</section>
