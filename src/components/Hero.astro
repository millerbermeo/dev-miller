---
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center px-4 sm:px-6 pt-24 md:pt-32 pb-16"
>
  <div class="max-w-4xl w-full mx-auto">
    <!-- Availability badge -->
    <div data-anim="hero-badge" class="flex items-center gap-2 mb-6 sm:mb-8">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 rounded-full"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"
          aria-hidden="true"
        ></span>
        Disponible para nuevos proyectos
      </span>
    </div>

    <!-- Headline -->
    <h1
      data-anim="hero-title"
      class="text-[2.5rem] sm:text-5xl lg:text-7xl font-bold tracking-tight leading-[1.08] mb-5 sm:mb-6"
    >
      <span class="text-white">Soy Miller Bermeo</span>
      <br />
      <span
        class="bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent"
      >
        Fullstack Developer & IA
      </span>
    </h1>

    <!-- Value proposition -->
    <p
      data-anim="hero-role"
      class="text-base sm:text-xl lg:text-2xl text-zinc-400 font-medium mb-4 sm:mb-5"
    >
      Backend · Automatización · Sistemas que escalan en producción
    </p>

    <p
      data-anim="hero-desc"
      class="text-sm sm:text-base lg:text-lg text-zinc-500 max-w-2xl leading-relaxed mb-8 sm:mb-10"
    >
      Construyo plataformas SaaS, sistemas POS y automatizaciones con IA que
      resuelven problemas reales de negocio.
      <span class="text-zinc-300 font-medium">
        3 años construyendo, 1.5 en producción profesional con impacto medible.
      </span>
    </p>

    <!-- CTAs -->
    <div
      data-anim="hero-cta"
      class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-3 sm:gap-4 mb-10 sm:mb-12"
    >
      <a
        href="#projects"
        class="px-6 py-3 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/20 text-center"
      >
        Ver proyectos →
      </a>
      <a
        href="cvmillerrivera.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 text-sm font-semibold text-zinc-300 bg-white/[.05] hover:bg-white/[.08] border border-white/[.08] rounded-lg transition-all duration-200 text-center"
      >
        Descargar CV
      </a>
      <a
        href="#contact"
        class="px-6 py-3 text-sm font-medium text-zinc-500 hover:text-zinc-300 transition-colors duration-200 text-center"
      >
        Trabajemos juntos ↓
      </a>
    </div>

    <!-- Social links -->
    <div
      data-anim="hero-social"
      class="flex flex-wrap items-center gap-4 sm:gap-5"
    >
      <a
        href="https://github.com/millerbermeo"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-zinc-500 hover:text-white transition-colors duration-200"
        aria-label="GitHub de Miller Bermeo"
      >
        <ion-icon name="logo-github" class="text-lg" aria-hidden="true"></ion-icon>
        <span>GitHub</span>
      </a>
      <a
        href="https://www.linkedin.com/in/miller-rivera/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-zinc-500 hover:text-white transition-colors duration-200"
        aria-label="LinkedIn de Miller Bermeo"
      >
        <ion-icon name="logo-linkedin" class="text-lg" aria-hidden="true"></ion-icon>
        <span>LinkedIn</span>
      </a>
      <a
        href="mailto:devmiller25@gmail.com"
        class="flex items-center gap-2 text-sm text-zinc-500 hover:text-white transition-colors duration-200"
        aria-label="Enviar email a Miller Bermeo"
      >
        <ion-icon name="mail-outline" class="text-lg" aria-hidden="true"></ion-icon>
        <span class="hidden sm:inline">devmiller25@gmail.com</span>
        <span class="sm:hidden">Email</span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#about"
    aria-label="Ir a la sección Sobre mí"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-zinc-700 hover:text-zinc-400 transition-colors duration-200 animate-bounce"
  >
    <span class="text-[10px] uppercase tracking-widest font-medium">Scroll</span>
    <ion-icon name="chevron-down-outline" class="text-base" aria-hidden="true"></ion-icon>
  </a>
</section>

<style>
  section {
    position: relative;
  }
</style>
