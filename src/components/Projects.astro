---
import { projects } from '../data/projects';
import CodexIcon from './icons/CodexIcon.astro';
import ClaudeCodeIcon from './icons/ClaudeCodeIcon.astro';
import OpenCodeIcon from './icons/OpenCodeIcon.astro';
import OpenClawIcon from './icons/OpenClawIcon.astro';

const copilotIcons: Record<string, any> = {
  "Codex": CodexIcon,
  "Claude Code": ClaudeCodeIcon,
  "OpenCode": OpenCodeIcon,
  "OpenClaw": OpenClawIcon,
};

const accentMap: Record<string, string> = {
  indigo: "border-indigo-500/30 text-indigo-400 bg-indigo-500/10",
  emerald: "border-emerald-500/30 text-emerald-400 bg-emerald-500/10",
  violet: "border-violet-500/30 text-violet-400 bg-violet-500/10",
  orange: "border-orange-500/30 text-orange-400 bg-orange-500/10",
  cyan: "border-cyan-500/30 text-cyan-400 bg-cyan-500/10",
  green: "border-green-500/30 text-green-400 bg-green-500/10",
};
---

<section id="projects" class="py-16 sm:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-indigo-400 mb-3"
    >
      Proyectos
    </p>
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-3 sm:mb-4">
      Trabajo destacado
    </h2>
    <p class="text-zinc-500 mb-8 sm:mb-12 text-sm sm:text-[15px]">
      Proyectos reales construidos en producción. Cada uno resolvió un problema
      concreto de negocio.
    </p>

    <div class="space-y-5 sm:space-y-6">
      {
        projects.map((project) => (
          <article
            data-anim="project-card"
            class="group bg-white/[.03] border border-white/[.07] rounded-2xl overflow-hidden hover:border-white/[.12] transition-all duration-300"
          >
            <div class="flex flex-col lg:flex-row">
              <!-- Image -->
              <div class="w-full h-44 sm:h-52 lg:w-64 lg:h-auto overflow-hidden flex-shrink-0 bg-zinc-900">
                <img
                  src={project.image}
                  alt={project.title}
                  width="256"
                  height="208"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-75 group-hover:opacity-100"
                />
              </div>

              <!-- Content -->
              <div class="flex-1 p-5 sm:p-6 min-w-0">
                <!-- Label -->
                <span
                  class={`inline-flex items-center px-2.5 py-1 text-xs font-semibold rounded-full border mb-3 ${accentMap[project.accent]}`}
                >
                  {project.label}
                </span>

                <h3 class="text-base sm:text-lg font-bold text-white mb-3 sm:mb-4">
                  {project.title}
                </h3>

                <div class="space-y-2.5 sm:space-y-3 mb-4 sm:mb-5">
                  <div class="flex flex-col sm:flex-row sm:gap-2 text-sm">
                    <span class="text-zinc-600 font-medium sm:flex-shrink-0 sm:w-20 mb-0.5 sm:mb-0">
                      Problema
                    </span>
                    <span class="text-zinc-400 text-xs sm:text-sm">{project.problem}</span>
                  </div>
                  <div class="flex flex-col sm:flex-row sm:gap-2 text-sm">
                    <span class="text-zinc-600 font-medium sm:flex-shrink-0 sm:w-20 mb-0.5 sm:mb-0">
                      Solución
                    </span>
                    <span class="text-zinc-400 text-xs sm:text-sm">{project.solution}</span>
                  </div>
                  <div class="flex flex-col sm:flex-row sm:gap-2 text-sm">
                    <span class="text-zinc-600 font-medium sm:flex-shrink-0 sm:w-20 mb-0.5 sm:mb-0">
                      Resultado
                    </span>
                    <span class="text-zinc-300 font-medium text-xs sm:text-sm">
                      {project.result}
                    </span>
                  </div>
                </div>

                <!-- Footer -->
                <div class="space-y-3 pt-3 sm:pt-4 border-t border-white/[.05]">
                  <div class="flex flex-wrap gap-1.5">
                    {project.stack.map((tech) => (
                      <span class="px-2 py-0.5 text-xs text-zinc-500 bg-white/[.03] border border-white/[.06] rounded-md">
                        {tech}
                      </span>
                    ))}
                  </div>
                  {project.copilots && project.copilots.length > 0 && (
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-xs text-zinc-600 font-medium">AI Copilot:</span>
                      {project.copilots.map((copilot: string) => {
                        const IconComponent = copilotIcons[copilot];
                        return (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 rounded-md">
                            {IconComponent && <IconComponent />}
                            {copilot}
                          </span>
                        );
                      })}
                    </div>
                  )}
                  <div class="flex items-center justify-between flex-wrap gap-3 pt-2">
                    <div class="flex items-center gap-3">
                      {project.deploy && (
                        <a
                          href={project.deploy}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex items-center gap-1.5 text-xs font-medium text-zinc-500 hover:text-white transition-colors duration-200 flex-shrink-0"
                        >
                          <ion-icon name="globe-outline" class="text-sm" />
                          Deploy
                        </a>
                      )}
                      {project.github && (
                        <a
                          href={project.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex items-center gap-1.5 text-xs font-medium text-zinc-500 hover:text-white transition-colors duration-200 flex-shrink-0"
                        >
                          <ion-icon name="logo-github" class="text-sm" />
                          GitHub
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- GitHub CTA -->
    <div class="mt-7 sm:mt-8 text-center">
      <a
        href="https://github.com/millerbermeo"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-zinc-400 hover:text-white bg-white/[.03] hover:bg-white/[.06] border border-white/[.08] rounded-lg transition-all duration-200"
      >
        <ion-icon name="logo-github" class="text-base"></ion-icon>
        Ver más en GitHub
      </a>
    </div>
  </div>
</section>
