---
const services = [
  {
    icon: "sparkles-outline",
    title: "Automatización con IA",
    desc: "Integro modelos de lenguaje (OpenAI, Claude) en tus procesos operativos para automatizar tareas repetitivas, clasificar información y generar respuestas inteligentes.",
    tags: ["OpenAI", "Claude API", "Agentes IA", "n8n"],
    accent: "indigo",
  },
  {
    icon: "server-outline",
    title: "Desarrollo Backend & APIs",
    desc: "Diseño y construyo APIs RESTful robustas, escalables y bien documentadas con Node.js/NestJS o Python/FastAPI. Arquitectura limpia, SOLID y orientada a producción.",
    tags: ["Node.js", "NestJS", "FastAPI", "PostgreSQL", "Docker"],
    accent: "violet",
  },
  {
    icon: "chatbubbles-outline",
    title: "Chatbots & Integraciones",
    desc: "Desarrollo chatbots funcionales para WhatsApp Business API con flujos conversacionales, lógica de negocio personalizada y conexión a tus sistemas existentes.",
    tags: ["WhatsApp API", "Chatbot", "Node.js", "Webhooks"],
    accent: "emerald",
  },
];

const accentBorder: Record<string, string> = {
  indigo: "hover:border-indigo-500/40",
  violet: "hover:border-violet-500/40",
  emerald: "hover:border-emerald-500/40",
};

const accentIcon: Record<string, string> = {
  indigo: "text-indigo-400 bg-indigo-500/10",
  violet: "text-violet-400 bg-violet-500/10",
  emerald: "text-emerald-400 bg-emerald-500/10",
};
---

<section id="services" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-indigo-400 mb-3"
    >
      Servicios
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      ¿En qué puedo ayudarte?
    </h2>
    <p class="text-zinc-500 mb-12 text-[15px]">
      Me enfoco en soluciones que generan valor real. Sin código innecesario, sin
      promesas vacías.
    </p>

    <div class="grid sm:grid-cols-3 gap-5">
      {
        services.map((service) => (
          <div
            data-anim="service-card"
            class={`bg-white/[.03] border border-white/[.07] rounded-2xl p-6 transition-all duration-300 ${accentBorder[service.accent]}`}
          >
            <div
              class={`w-10 h-10 rounded-xl flex items-center justify-center mb-5 ${accentIcon[service.accent]}`}
            >
              <ion-icon name={service.icon} class="text-xl" />
            </div>
            <h3 class="text-base font-semibold text-white mb-3">
              {service.title}
            </h3>
            <p class="text-sm text-zinc-500 leading-relaxed mb-5">
              {service.desc}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {service.tags.map((tag) => (
                <span class="px-2 py-0.5 text-xs text-zinc-600 bg-white/[.03] border border-white/[.05] rounded-md">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors duration-200"
      >
        ¿Tienes un proyecto en mente? Hablemos →
      </a>
    </div>
  </div>
</section>
