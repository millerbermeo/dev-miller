---
import HtmlIcon from "./icons/HtmlIcon.astro";
import CssIcon from "./icons/CssIcon.astro";
import JavascriptIcon from "./icons/JavascriptIcon.astro";
import Tailwindicon from "./icons/Tailwindicon.astro";
import ReactIcon from "./icons/ReactIcon.astro";
import AstroIcon from "./icons/AstroIcon.astro";
import NextjsIcon from "./icons/NextjsIcon.astro";
import NodeIcon from "./icons/NodeIcon.astro";
import MysqlIcon from "./icons/MysqlIcon.astro";
import DockerIcon from "./icons/DockerIcon.astro";
import GitIcon from "./icons/GitIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import LInuxIcon from "./icons/LInuxIcon.astro";

const categories = [
  {
    label: "Lenguajes",
    items: [
      { name: "Python", color: "#3776AB", letter: "Py" },
      { name: "JavaScript", icon: "js" },
    ],
  },
  {
    label: "Frontend",
    items: [
      { name: "HTML", icon: "html" },
      { name: "CSS", icon: "css" },
      { name: "Tailwind CSS", icon: "tailwind" },
      { name: "React", icon: "react" },
      { name: "Next.js", icon: "nextjs" },
      { name: "Astro", icon: "astro" },
    ],
  },
  {
    label: "Backend",
    items: [
      { name: "Node.js", icon: "node" },
      { name: "NestJS", color: "#E0234E", letter: "Ne" },
      { name: "FastAPI", color: "#009688", letter: "FA" },
      { name: "Flask", color: "#FFFFFF", letter: "Fl" },
    ],
  },
  {
    label: "Bases de datos",
    items: [
      { name: "PostgreSQL", color: "#336791", letter: "PG" },
      { name: "MySQL", icon: "mysql" },
    ],
  },
  {
    label: "DevOps & Cloud",
    items: [
      { name: "Docker", icon: "docker" },
      { name: "Linux", icon: "linux" },
      { name: "AWS", color: "#FF9900", letter: "AWS" },
    ],
  },
  {
    label: "Integraciones & IA",
    items: [
      { name: "OpenAI API", color: "#74AA9C", letter: "AI" },
      { name: "Claude API", color: "#D4A574", letter: "Cl" },
      { name: "WhatsApp API", color: "#25D366", letter: "WA" },
    ],
  },
  {
    label: "Herramientas",
    items: [
      { name: "Git", icon: "git" },
      { name: "GitHub", icon: "github" },
      { name: "REST APIs", color: "#6366f1", letter: "API" },
      { name: "Principios SOLID", color: "#8B5CF6", letter: "S" },
    ],
  },
];
---

<section id="stack" class="py-16 sm:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-indigo-400 mb-3"
    >
      Tecnologías
    </p>
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-3 sm:mb-4">
      Stack tecnológico
    </h2>
    <p class="text-zinc-500 mb-8 sm:mb-12 text-sm sm:text-[15px]">
      Herramientas con las que construyo soluciones reales en producción.
    </p>

    <div class="space-y-8">
      {
        categories.map((cat) => (
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-zinc-600 mb-3">
              {cat.label}
            </p>
            <div class="flex flex-wrap gap-2">
              {cat.items.map((item) => (
                <div data-anim="stack-item" class="flex items-center gap-2 px-3 py-2 bg-white/[.03] border border-white/[.07] rounded-xl hover:border-white/[.14] hover:bg-white/[.05] transition-all duration-200 cursor-default">
                  {item.icon === "html" && (
                    <span class="icon-wrap">
                      <HtmlIcon />
                    </span>
                  )}
                  {item.icon === "css" && (
                    <span class="icon-wrap">
                      <CssIcon />
                    </span>
                  )}
                  {item.icon === "js" && (
                    <span class="icon-wrap">
                      <JavascriptIcon />
                    </span>
                  )}
                  {item.icon === "tailwind" && (
                    <span class="icon-wrap">
                      <Tailwindicon />
                    </span>
                  )}
                  {item.icon === "react" && (
                    <span class="icon-wrap">
                      <ReactIcon />
                    </span>
                  )}
                  {item.icon === "nextjs" && (
                    <span class="icon-wrap">
                      <NextjsIcon />
                    </span>
                  )}
                  {item.icon === "astro" && (
                    <span class="icon-wrap">
                      <AstroIcon />
                    </span>
                  )}
                  {item.icon === "node" && (
                    <span class="icon-wrap">
                      <NodeIcon />
                    </span>
                  )}
                  {item.icon === "mysql" && (
                    <span class="icon-wrap">
                      <MysqlIcon />
                    </span>
                  )}
                  {item.icon === "docker" && (
                    <span class="icon-wrap">
                      <DockerIcon />
                    </span>
                  )}
                  {item.icon === "linux" && (
                    <span class="icon-wrap">
                      <LInuxIcon />
                    </span>
                  )}
                  {item.icon === "git" && (
                    <span class="icon-wrap">
                      <GitIcon />
                    </span>
                  )}
                  {item.icon === "github" && (
                    <span class="icon-wrap">
                      <GithubIcon />t
                    </span>
                  )}
                  {item.color && item.letter && (
                    <span
                      class="w-5 h-5 flex-shrink-0 rounded text-[9px] font-bold flex items-center justify-center"
                      style={`background-color: ${item.color}22; color: ${item.color}; border: 1px solid ${item.color}44;`}
                    >
                      {item.letter}
                    </span>
                  )}
                  <span class="text-sm text-zinc-300 font-medium whitespace-nowrap">
                    {item.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .icon-wrap svg {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }
</style>
