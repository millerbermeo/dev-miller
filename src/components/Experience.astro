---
const responsibilities = [
  {
    icon: "storefront-outline",
    title: "Sistemas POS & SaaS",
    desc: "Desarrollo de plataformas de punto de venta con módulos de inventario, caja, ventas y reportes en tiempo real.",
  },
  {
    icon: "car-outline",
    title: "Sistema de Gestión de Vehículos",
    desc: "Plataforma fullstack para venta y gestión de flota vehicular: inventario, seguimiento y panel administrativo.",
  },
  {
    icon: "chatbubbles-outline",
    title: "Chatbots con WhatsApp API",
    desc: "Bots de atención automatizada integrados con WhatsApp Business API, con flujos conversacionales y lógica de negocio.",
  },
  {
    icon: "sparkles-outline",
    title: "Integración de IA (OpenAI & Claude)",
    desc: "Implementación de modelos de lenguaje para automatización de respuestas, clasificación y asistentes inteligentes.",
  },
  {
    icon: "bicycle-outline",
    title: "Sistema de Domicilios Automatizado",
    desc: "Plataforma de delivery con asignación inteligente de pedidos, seguimiento en tiempo real y automatización con IA.",
  },
  {
    icon: "globe-outline",
    title: "Landing Pages & Sitios Web",
    desc: "Desarrollo de páginas de aterrizaje optimizadas para conversión, carga rápida y posicionamiento SEO.",
  },
];

const stack = [
  "Node.js",
  "NestJS",
  "Python",
  "FastAPI",
  "React",
  "Next.js",
  "PostgreSQL",
  "MySQL",
  "Docker",
  "AWS",
  "WhatsApp API",
  "OpenAI API",
  "Claude API",
  "Linux",
];
---

<section id="experience" class="py-16 sm:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-indigo-400 mb-3"
    >
      Trayectoria
    </p>
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-8 sm:mb-12">
      Experiencia laboral
    </h2>

    <div class="relative">
      <!-- Timeline bar -->
      <div
        class="absolute left-0 top-3 bottom-8 w-px bg-gradient-to-b from-indigo-500/60 via-white/10 to-transparent hidden sm:block"
      ></div>

      <div class="sm:pl-8 relative">
        <!-- Timeline dot -->
        <div
          class="hidden sm:block absolute -left-[4.5px] top-[14px] w-2.5 h-2.5 rounded-full bg-indigo-400 ring-4 ring-[#080808]"
        ></div>

        <!-- Experience card -->
        <div
          data-anim="exp-card"
          class="bg-white/[.03] border border-white/[.08] rounded-2xl p-5 sm:p-8"
        >
          <!-- Header -->
          <div
            class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-6 sm:mb-8"
          >
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-white">
                Desarrollador de Software
              </h3>
              <p class="text-indigo-400 font-medium mt-1">Desarrollo G</p>
              <p class="text-xs text-zinc-600 mt-1.5">
                Empresa de tecnología · Soluciones a medida
              </p>
            </div>
            <span
              class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-zinc-400 bg-white/[.04] border border-white/[.06] rounded-full self-start sm:whitespace-nowrap"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"
              ></span>
              2023 — Actualidad · 1.5 años
            </span>
          </div>

          <!-- Responsibilities grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {
              responsibilities.map((item) => (
                <div class="flex gap-3 p-3 sm:p-4 rounded-xl bg-white/[.02] border border-white/[.05] hover:border-white/[.1] transition-colors duration-200">
                  <ion-icon
                    name={item.icon}
                    class="text-indigo-400 text-xl flex-shrink-0 mt-0.5"
                  />
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-zinc-200">
                      {item.title}
                    </p>
                    <p class="text-xs text-zinc-500 mt-1 leading-relaxed">
                      {item.desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Stack -->
          <div class="mt-6 pt-5 border-t border-white/[.06]">
            <p
              class="text-xs font-semibold uppercase tracking-wider text-zinc-600 mb-3"
            >
              Stack utilizado
            </p>
            <div class="flex flex-wrap gap-2">
              {
                stack.map((tech) => (
                  <span class="px-2.5 py-1 text-xs text-zinc-400 bg-white/[.04] border border-white/[.06] rounded-md hover:border-indigo-500/30 hover:text-zinc-200 transition-colors duration-200">
                    {tech}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
