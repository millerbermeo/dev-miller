---
import Header from "../components/Header.astro";
import "@fontsource-variable/onest";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Miller Bermeo — Desarrollador Fullstack & IA",
  description = "Desarrollador Fullstack con 3 años de experiencia construyendo sistemas POS, SaaS, chatbots con IA y automatizaciones orientadas a negocio. Backend · Node.js · Python · React.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="desarrollador fullstack, backend developer, inteligencia artificial, automatización, Node.js, Python, NestJS, React, Next.js, Colombia, portafolio"
    />
    <meta name="author" content="Miller Bermeo" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Miller Bermeo - Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Fixed dark background with grid -->
    <div class="fixed inset-0 -z-10 bg-[#080808]">
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff06_1px,transparent_1px),linear-gradient(to_bottom,#ffffff06_1px,transparent_1px)] bg-[size:72px_72px]"
      ></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-5%,rgba(99,102,241,0.1),transparent)]"
      ></div>
    </div>

    <Header />
    <slot />

    <script
      is:inline
      type="module"
      src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"
    ></script>
    <script
      is:inline
      nomodule
      src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"
    ></script>

    <script>
      import "../scripts/animations.js";
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
    color-scheme: dark;
  }

  body {
    color: #fafafa;
    overflow-x: hidden;
  }

  ::selection {
    background: rgba(99, 102, 241, 0.35);
    color: #fafafa;
  }

  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-track {
    background: #080808;
  }
  ::-webkit-scrollbar-thumb {
    background: #27272a;
    border-radius: 2px;
  }

  /* Smooth section transitions */
  section {
    scroll-margin-top: 5rem;
  }
</style>
